PORT=3001
FRONTEND_URL=http://localhost:3000

# HMAC key used to sign /download/:token URLs. Required at startup.
# Generate with: openssl rand -hex 32
# Use a dedicated secret distinct from SUPABASE_SECRET_KEY.
DOWNLOAD_SIGNING_SECRET=replace-with-a-random-32-byte-hex-string
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=mike

GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
# NVIDIA API Catalog (build.nvidia.com). Optional NVIDIA_BASE_URL lets you
# point at a self-hosted NIM or local OpenAI-compatible server (Ollama, vLLM).
NVIDIA_API_KEY=your-nvidia-key
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
RESEND_API_KEY=your-resend-key
USER_API_KEYS_ENCRYPTION_SECRET=your-long-random-secret

# Med-mal PDF extraction (Phase 2). Default: setImmediate in API process.
# For serverless / multi-instance: EXTRACTION_ASYNC_MODE=queue (worker polls DB).
# EXTRACTION_ASYNC_MODE=queue
# EXTRACTION_JOB_POLL_MS=2000
# MED_MAL_EXTRACTION_MODEL=claude-sonnet-4-6
